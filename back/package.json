{
  "name": "@mccbng/back",
  "version": "1.0.0",
  "description": "API mccbng : mCloud Compte and Budget Next Generation",
  "keywords": [
    "loopback-application",
    "loopback"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "lint": "pnpm run eslint && pnpm run prettier:check",
    "lint:fix": "pnpm run eslint:fix && pnpm run prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "pnpm run prettier:cli -l",
    "prettier:fix": "pnpm run prettier:cli --write",
    "eslint": "eslint --report-unused-disable-directives --ext .js,.ts .",
    "eslint:fix": "pnpm run eslint --fix",
    "pretest": "pnpm run rebuild",
    "test": "lb-mocha --allow-console-logs \"dist/__tests__\"",
    "posttest": "pnpm run lint",
    "test:dev": "lb-mocha --allow-console-logs dist/__tests__/**/*.js && pnpm run posttest",
    "premigrate": "pnpm run build",
    "migrate": "node ./dist/migrate",
    "preopenapi-spec": "pnpm run build",
    "openapi-spec": "node ./dist/openapi-spec",
    "rebuild": "pnpm run clean && pnpm run build",
    "prestart": "pnpm run rebuild",
    "start": "node -r source-map-support/register .",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "docker:staging:build": "docker buildx build --platform linux/amd64 -t dockregistry.xju.fr/mccbng/api:staging .",
    "docker:staging:push": "docker push dockregistry.xju.fr/mccbng/api:staging",
    "docker:latest:build": "docker buildx build --platform linux/amd64 -t dockregistry.xju.fr/mccbng/api:latest .",
    "docker:latest:push": "docker push dockregistry.xju.fr/mccbng/api:latest",
    "docker:run": "docker run -p 3000:3000 --name mccbng_api --rm --mount type=bind,source=/Users/xjulien/Git/Perso/mccbng/back/dist/datasources/mccb-mysql.datasource.config.json,target=/home/node/app/dist/datasources/mccb-mysql.datasource.config.json -d dockregistry.xju.fr/mccbng/api:staging",
    "docker:inspect": "docker exec -it mccbng_api bash",
    "docker:stop": "docker stop mccbng_api"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "Xavier JULIEN <xavijulien@gmail.com>",
  "license": "MIT",
  "files": [
    "README.md",
    "dist",
    "src",
    "!*/__tests__"
  ],
  "dependencies": {
    "@loopback/authentication": "^12.0.0",
    "@loopback/authentication-jwt": "^0.16.0",
    "@loopback/boot": "^8.0.0",
    "@loopback/core": "^7.0.0",
    "@loopback/repository": "^8.0.0",
    "@loopback/rest": "^15.0.0",
    "@loopback/rest-explorer": "^8.0.0",
    "@loopback/service-proxy": "^8.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "loopback-connector-mysql": "^8.0.0",
    "tslib": "^2.8.0"
  },
  "devDependencies": {
    "@loopback/build": "^12.0.0",
    "@loopback/eslint-config": "^16.0.0",
    "@loopback/testlab": "^8.0.0",
    "@types/express": "^4.17.9",
    "@types/node": "^25.0.0",
    "eslint": "^8.57.0",
    "eslint-config-loopback": "^14.0.0",
    "nsp": "^3.2.1",
    "source-map-support": "^0.5.21",
    "typescript": "^5.2.2"
  }
}